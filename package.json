{
	"name": "suffle",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend:delayed\"",
		"dev:frontend": "vite dev",
		"dev:frontend:delayed": "sleep 2 && vite dev",
		"dev:backend": "node dev-server-simple.js",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "npx vercel --prod",
		"deploy:preview": "npx vercel",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@vitest/browser-playwright": "^4.0.18",
		"concurrently": "^9.2.1",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"tailwindcss": "^4.1.18",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.99.3",
		"bcryptjs": "^3.0.3",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"gracket": "^2.1.1",
		"jsonwebtoken": "^9.0.3",
		"jspdf": "^4.2.0",
		"jspdf-autotable": "^5.0.7"
	}
}
